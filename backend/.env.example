# ─── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Anthropic (Claude AI) ───────────────────────────
# Used for all 3 skills: ingestion, classification, envelope-prep
ANTHROPIC_API_KEY=

# ─── DocuSign ────────────────────────────────────────
DOCUSIGN_BASE_URL=https://na4.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=
# Access token from DocuSign OAuth (JWT or Auth Code flow)
# The frontend can pass this per-request, or set here for webhook auto-send
DOCUSIGN_ACCESS_TOKEN=

# ─── Agreement Desk (Email Inbox) ────────────────────
# IMAP credentials for your Agreement Desk inbox
AGREEMENT_DESK_EMAIL=
AGREEMENT_DESK_IMAP_HOST=imap.gmail.com
AGREEMENT_DESK_IMAP_PORT=993
AGREEMENT_DESK_IMAP_PASSWORD=
AGREEMENT_DESK_MAILBOX=INBOX

# ─── Auto-send settings ──────────────────────────────
# If set, envelopes are auto-sent when email webhook fires
# (otherwise, envelope_config is returned for manual dispatch)
DEFAULT_SIGNER_EMAIL=

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/docusign_healthcare

# ─── AWS S3 (optional — for document storage) ────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=docusign-healthcare-faxes

# ─── Redis (optional — for job queue) ────────────────
REDIS_URL=redis://localhost:6379
